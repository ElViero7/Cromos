    "@mantine/modals": "^7.17.8",
    "@mantine/notifications": "^7.17.8",
    "@supabase/supabase-js": "^2.105.1",
    "@tanstack/react-query": "^5.100.6",
    "lucide-react": "^1.12.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
